-- SIMPLE AIMBOT (RMB hold)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function GetClosestTarget()
    local best, closest = nil, 9999
    local mouse = UserInputService:GetMouseLocation()
    for _, p in Players:GetPlayers() do
        if p == LocalPlayer then continue end
        local char = p.Character
        if not (char and char:FindFirstChild(Settings.AimPart)) then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not (hum and hum.Health > 0) then continue end
        local teammate = p.Team == LocalPlayer.Team and LocalPlayer.Team ~= nil
        if not Settings.TargetTeam and teammate then continue end
        local pos, onScreen = Camera:WorldToViewportPoint(char[Settings.AimPart].Position)
        if not onScreen then continue end
        local dist = (Vector2.new(pos.X, pos.Y) - mouse).Magnitude
        if dist < closest then
            closest = dist
            best = char[Settings.AimPart]
        end
    end
    return best
end
RunService.Heartbeat:Connect(function()
    if not Settings.AimbotEnabled then return end
    if not Settings.AimbotActive then return end
    if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
    local targetPart = GetClosestTarget()
    if targetPart then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
    end
end)
